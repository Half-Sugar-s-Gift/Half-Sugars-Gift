"role.wish.name" : "「愿」"
"role.wish.blurb" : "愿下次相遇不是阴阳两隔"
"role.wish.short" : "愿"
"role.wish.doc" : "使用<b>祈愿</b>为玩家添加标记，查看凶手信息/保护其不被放逐"
"role.wish.ability.title" : "<b>固有能力【祈愿】</b>"
"role.wish.ability.main" : "可以使用<b>祈愿</b>来为他人叠加一层标记，<br>当那人被标记，如果他死亡，你得知凶手信息。<br>如果他被放逐，将阻止本次放逐。<br>根据房主设置，<b>祈愿</b>叠加给伪装者，船员，中立阵营时，愿是否会自杀。"
"role.wish.doc.wishSkill" : "<b>祈愿</b><br>在行动阶段标记他人"
"role.wish.tips" : " "
"options.role.wish.detail" : "愿可以标记他人并产生技能效果<br><b>这是半糖送给你的礼物之一！</b>"
"options.role.wish.MarkCoolDown" : "技能冷却"
"options.role.wish.MarkMaxUses" : "技能使用次数上限"
"options.role.wish.suicideImpostor" : "祈愿伪装者时是否暴毙"
"options.role.wish.suicideNeutral" : "祈愿中立阵营是否暴毙"
"options.role.wish.suicideCrewmate" : "祈愿船员是否暴毙"
"button.label.wish.mark" : "祈愿"
"role.wish.markdead" : "「愿」星空中那名为“<color=#%COLOR%>%VICTIM%</color>”的星光，<br>黯淡地消逝在了名为“%KILLER%”的手中。"
"role.wish.murdererdead" : "「愿」星空中那名为“<color=#%COLOR%>%VICTIM%</color>”的星光，<br>与其凶手一同消逝在了空中。"


"role.snitch.name" : "告密者"
"role.snitch.blurb" : "我一定会将这份情报，安全地带回去！"
"role.snitch.short" : "告"
"role.snitch.canBeGuess.true" : "你仍然可以被赌杀"
"role.snitch.canBeGuess.false" : "你将无法被赌杀"
"role.snitch.imposter.all" : "得知所有伪装者"
